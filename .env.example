# Database (Neon Serverless Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js (NextAuth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # Generate: openssl rand -base64 32

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI (optional)
GEMINI_API_KEY=""

# Paddle Billing (optional — feature disabled when absent)
# PADDLE_API_KEY=""
# PADDLE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
# NEXT_PUBLIC_PADDLE_ENV="sandbox"           # "sandbox" | "production"
# NEXT_PUBLIC_PADDLE_PRICE_ID=""

# Contact/Feedback Email recipient (optional)
# FEEDBACK_TO_EMAIL="hello@yourdomain.com"

# Transactional Email — Resend (optional — logs to console when absent)
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="hello@yourdomain.com"

# Analytics (optional — pick one or both)
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# NEXT_PUBLIC_GA_ID=""               # Google Analytics 4 Measurement ID (G-XXXXXXXXXX)

# Error Monitoring — Sentry (optional — logs to console when absent)
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""                   # Sourcemap upload (build time only)
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# Upstash Redis (optional — falls back to in-memory rate limiting when absent)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# CORS (optional — defaults to "http://localhost:3000" in dev, set to your domain in production)
# CORS_ORIGIN="https://yourdomain.com"

# PWA (optional — disabled when absent or not "true")
# NEXT_PUBLIC_PWA_ENABLED="true"

# Google Maps (optional — map component shows placeholder when absent)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Development Tools
# ANALYZE="true"                       # Enable @next/bundle-analyzer (pnpm analyze)
