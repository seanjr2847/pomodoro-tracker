# Database (Neon Serverless Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js (NextAuth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # Generate: openssl rand -base64 32

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI (optional)
GEMINI_API_KEY=""

# Paddle Billing (optional — feature disabled when absent)
# PADDLE_API_KEY=""
# PADDLE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""  # Paddle Dashboard > Developer Tools > Authentication
# NEXT_PUBLIC_PADDLE_PRICE_ID=""      # Pro plan price ID (pri_...)
# NEXT_PUBLIC_PADDLE_ENV="sandbox"    # "sandbox" or "production"

# Transactional Email — Resend (optional — logs to console when absent)
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="hello@yourdomain.com"

# Analytics (optional — pick one or both)
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# NEXT_PUBLIC_GA_ID=""               # Google Analytics 4 Measurement ID (G-XXXXXXXXXX)

# Error Monitoring — Sentry (optional — logs to console when absent)
# NEXT_PUBLIC_SENTRY_DSN=""
